// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// run `npx prisma generate` and `npx prisma migrate dev --name <name>` from mb/server

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id                   Int          @id @default(autoincrement()) 
  email                String       @unique
  username             String       @unique
  password             String 
  salt                 String
  createdAt            DateTime     @default(now())
  lastOnline           DateTime     @default(now())
  totalExp             Int          @default(0)
  level                Int          @default(0)
  rank                 String       @default("Unranked")
  gamesPlayed          Int          @default(0)
  wins                 Int          @default(0)
  losses               Int          @default(0)
  avgAnswerTime        Float        @default(0.0)
  timePlayed           Float        @default(0.0) // in hours?
  friends              Int          @default(0)
  mbrr                 Int          @default(1000) // mathblitz rank rating
  bestSurvivalScore    Int          @default(0)
  bestScore            Int          @default(0)
  
  friendshipsInitiated Friendship[] @relation("UserFriendships")
  friendshipsReceived  Friendship[] @relation("FriendFriendships")

  gameHistory          GamePlayer[]
  
  notifications        Notification[]
} 

model Friendship {
  id        Int      @id @default(autoincrement())
  
  // The user who sent the friend request
  userId    Int      
  user      User     @relation("UserFriendships", fields: [userId], references: [id])
  
  // The user who received the friend request
  friendId  Int      
  friend    User     @relation("FriendFriendships", fields: [friendId], references: [id])
  
  // Friendship state (e.g., PENDING, ACCEPTED, BLOCKED)
  status    String   @default("PENDING") 
  createdAt DateTime @default(now())

  // Ensure a user can't send multiple requests to the exact same person
  @@unique([userId, friendId]) 
}

model Game {
  id        String     @id 
  status    String     @default("WAITING") // WAITING, IN_PROGRESS, FINISHED
  createdAt DateTime   @default(now())
  type      String     // custom, competitive, training, etc.

  questions Question[] 
  players   GamePlayer[]
}

model GamePlayer {
  id        Int      @id @default(autoincrement())
  
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id])

  score     Int      @default(0)
  isWinner  Boolean  @default(false)
  
  joinedAt  DateTime @default(now())

  @@unique([userId, gameId]) 
}

model Question {
  id            Int      @id @default(autoincrement())
  gameId        String
  game          Game     @relation(fields: [gameId], references: [id])
  question      String   // "2+2" 
  correctAnswer Int      // 4
}

model Notification {
  id            Int         @id @default(autoincrement())
  userId        Int         // user receiving the notification
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String      // friend request, system, achievement
  message       String
  link          String?     // optional
  isRead        Boolean     @default(false)
  createdAt     DateTime    @default(now())
}